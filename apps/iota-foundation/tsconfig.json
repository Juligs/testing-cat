{
    "extends": "@repo/typescript-config/nextjs.json",
    "compilerOptions": {
        "plugins": [
            {
                "name": "next"
            }
        ],
        "baseUrl": "./",
        "paths": {
            "@lib/*": ["app/lib/*"],
            "@components": ["app/components"],
            "@components/*": ["app/components/*"],
            "@sections": ["app/sections"],
            "@sections/*": ["app/sections/*"],
            "@repo/shared": ["../../shared"],
            "@repo/shared/*": ["../../shared/*"]
        }
    },
    "include": [
        "../../shared/**/*.ts",
        "../../shared/**/*.tsx",
        "next-env.d.ts",
        "next.config.mjs",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".eslintrc.js",
        "*.config.js"
    ],
    "exclude": ["node_modules"]
}
