{
    "extends": "@repo/typescript-config/nextjs.json",
    "compilerOptions": {
        "plugins": [
            {
                "name": "next"
            }
        ],
        "baseUrl": "./",
        "paths": {
            "@lib/*": ["app/lib/*"],
            "@components": ["app/components"],
            "@components/*": ["app/components/*"]
        }
    },
    "include": [
        "next-env.d.ts",
        "next.config.mjs",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".eslintrc.js",
        "*.config.js"
    ],
    "exclude": ["node_modules"]
}
