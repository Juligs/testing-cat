{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "globalEnv": [
        "NEXT_PUBLIC_IOTALABS_GOOGLE_ANALYTICS_ID",
        "IOTALABS_AIRTABLE_KEY",
        "NEXT_PUBLIC_IOTANETWORK_GOOGLE_ANALYTICS_ID",
        "NEXT_PUBLIC_IOTAFOUNDATION_GOOGLE_ANALYTICS_ID",
        "IOTA_NETWORK_INDEXER_URL",
        "IOTA_PRICE_URL"
    ],
    "tasks": {
        "build": {
            "dependsOn": ["^react-ui-kit#package"],
            "inputs": ["$TURBO_DEFAULT$", ".env*", "../../shared/public/**"],
            "outputs": [".next/**", "!.next/cache/**"],
            "env": ["BUILDING_PACKAGE", "BUILD_MODE"]
        },
        "build:all": {
            "dependsOn": ["react-ui-kit#package", "^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".next/**", "!.next/cache/**"],
            "env": ["BUILDING_PACKAGE", "BUILD_MODE"]
        },
        "lint": {
            "dependsOn": ["react-ui-kit#package", "^lint"]
        },
        "dev": {
            "cache": false,
            "persistent": true,
            "dependsOn": ["react-ui-kit#package"]
        },
        "typecheck": {
            "dependsOn": ["react-ui-kit#package", "^typecheck"]
        },
        "format:check": {},
        "package": {
            "env": ["BUILDING_PACKAGE", "BUILD_MODE"]
        },
        "react-ui-kit#package": {}
    }
}
