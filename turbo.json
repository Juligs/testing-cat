{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["react-ui-kit#package", "^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".next/**", "!.next/cache/**"],
            "env": ["BUILDING_PACKAGE"]
        },
        "lint": {
            "dependsOn": ["react-ui-kit#package", "^lint"]
        },
        "dev": {
            "cache": false,
            "persistent": true,
            "dependsOn": ["react-ui-kit#package"]
        },
        "typecheck": {
            "dependsOn": ["react-ui-kit#package", "^typecheck"]
        },
        "format:check": {},
        "package": {
            "env": ["BUILDING_PACKAGE"]
        },
        "react-ui-kit#package": {}
    }
}
